# Microsoft app registration values
TENANT_ID=your-tenant-id
CLIENT_ID=your-application-client-id
CLIENT_SECRET=your-client-secret-value

# Agent key to mailbox map, as a single JSON string.
# Generate one long random key per agent (for example with: openssl rand -hex 24)
# then map each key to the mailbox that agent should use.
AGENT_MAILBOX_MAP='{"":"reservations@kwantu.co.za","":"assistant@kwantu.co.za","":"assistant@sapphireglobalfs.com"}'

# Optional. If set, ChatGPT must send "Authorization: Bearer <token>" on every
# request or the endpoint returns 401. Leave empty/unset to skip this check.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MCP_AUTH_TOKEN=
