TENANT_ID=your-tenant-id
CLIENT_ID=your-application-client-id
CLIENT_SECRET=your-client-secret-value

# Agent key to mailbox map, single line JSON.
# Generate one key per agent:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AGENT_MAILBOX_MAP={"agent-key-1":"mailbox1@example.com","agent-key-2":"mailbox2@example.com"}

# Optional. If set, callers must send: Authorization: Bearer <token>
MCP_AUTH_TOKEN=